# 复制为项目根目录 .env 后按需修改
# SQLite，相对路径相对仓库根；生产可写绝对路径如 file:/data/node-apps/volleyball_drill/data/volleyball.db
DATABASE_URL=file:./data/volleyball.db

JWT_ACCESS_SECRET=change-me-to-long-random-string

# 分享页链接前缀（生产: https://volleyball.itorange.online）
PUBLIC_APP_URL=https://volleyball.itorange.online

# API 监听（开发本机；生产 PM2 + Nginx 反代见 docs/deploy-tencent.md，默认 3003）
PORT=3003
HOST=0.0.0.0
