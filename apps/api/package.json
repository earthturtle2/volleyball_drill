{
  "name": "@volleyball/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file ../../.env --env-file-if-exists=../../.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file ../../.env dist/index.js",
    "db:push": "node scripts/prepare-db-push.cjs && drizzle-kit push --config drizzle.config.cjs",
    "db:studio": "drizzle-kit studio --config drizzle.config.cjs"
  },
  "dependencies": {
    "@volleyball/shared": "*",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
