# 复制到 /etc/nginx/conf.d/volleyball.itorange.online.conf
# 证书路径请按本机 certbot / 腾讯云证书实际位置修改。

server {
    listen 80;
    listen [::]:80;
    server_name volleyball.itorange.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name volleyball.itorange.online;

    # ssl_certificate     /etc/letsencrypt/live/itorange.online/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/itorange.online/privkey.pem;

    root /data/node-apps/volleyball_drill/apps/web/dist;
    index index.html;

    # 前端 SPA：由 Vite 构建的 history 路由
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 反代 API：保留 /api 前缀，与 apps/api 中 register(..., { prefix: "/api/v1" }) 一致
    location /api/ {
        proxy_pass http://127.0.0.1:3003;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
